---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectList from "../components/ProjectList.astro";
import { basePath } from "../lib/paths";

const base = basePath;
const year = new Date().getFullYear();

const experience = [
  {
    title: "AI & software engineering intern, 2Ai IPCA",
    description: "International internship using real clinical imaging data. I built a Python DICOM/OCR pipeline, validation and review tools, resumable batch processing, ECG extraction, and a source-video matcher. Metadata-guided alignment reduced one representative run from about 21 hours to 23 minutes.",
  },
  {
    title: "Software engineer, Apolloon 24-hour run system",
    href: `${base}work/apolloon.html`,
    description: "Paid client work. I designed and implemented a local-first race operations platform with realtime synchronisation, automatic LAN discovery, SQLite replication, and failover for unreliable event conditions.",
    secondaryLabel: "Case study",
    secondaryHref: `${base}work/apolloon.html`,
  },
];

const selectedWork = [
  {
    title: "Financial AI agent",
    href: `${base}work/financial-agent.html`,
    description: "A six-service application with FastAPI streaming, MCP tool execution, RAG, PostgreSQL, React, ChromaDB, and local Ollama inference. Submitted as a two-person project; I implemented nearly all of the technical work end to end.",
    secondaryLabel: "Architecture and engineering case study",
    secondaryHref: `${base}work/financial-agent.html`,
  },
  {
    title: "Azure ML lifecycle",
    href: `${base}work/azure-mlops.html`,
    description: "Individual MLOps coursework covering Azure ML compute, parallel data preparation, model registration, MLflow, FastAPI, Docker, Kubernetes manifests, and GitHub Actions.",
    secondaryLabel: "Case study",
    secondaryHref: `${base}work/azure-mlops.html`,
  },
  {
    title: "Semi-supervised learning in Rust",
    href: `${base}blog/blog.html`,
    description: "Bachelor research into data-efficient plant-disease classification on edge devices. The saved SSL checkpoint reached 94.90% held-out accuracy and shipped as an approximately 26 MB offline application tested on iPhone.",
    secondaryLabel: "Read the technical case study",
    secondaryHref: `${base}blog/blog.html`,
  },
  {
    title: "Event chatbot for XPO Group",
    href: "https://github.com/SnaetWarre/Industry-Project-Xpo-Group",
    description: "Academic team project for an external client: a full-stack RAG system using Azure OpenAI, Cosmos DB, .NET, Next.js, and Python ingestion.",
  },
  {
    title: "Dataset query system",
    href: "https://github.com/SnaetWarre/Server-Client-Python",
    description: "A Python client-server analysis application with authentication, moderation, statistics, broadcasts, and a PySide6 interface.",
  },
];

const openSource = [
  {
    title: "Athas code editor · Maintainer & contributor",
    href: "https://github.com/athasdev/athas",
    description: "I contribute across its React/TypeScript and Tauri/Rust codebase. Merged work includes C# language support, image diffing, Linux UI improvements, dynamic proxy ports, resource- and memory-leak fixes, and an LSP race-condition fix.",
  },
];

const profileSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  mainEntity: {
    "@type": "Person",
    name: "Warre Snaet",
    jobTitle: "Junior Backend and Applied AI Engineer",
    url: "https://snaetwarre.github.io/My-Portofolio/",
    sameAs: ["https://www.linkedin.com/in/warre-snaet-272354370/", "https://github.com/SnaetWarre"],
    alumniOf: { "@type": "EducationalOrganization", name: "Howest University of Applied Sciences" },
  },
};
---

<BaseLayout
  title="Warre Snaet | Backend & Applied AI Engineer"
  description="Warre Snaet is an AI Engineering graduate with distinction from Belgium, building dependable Python backends, agent infrastructure, applied AI systems, and data pipelines."
>
  <Fragment slot="head"><script is:inline type="application/ld+json" set:html={JSON.stringify(profileSchema)} /></Fragment>
  <a class="skip-link" href="#main">Skip to content</a>
  <main id="main">
    <header>
      <h1>Warre Snaet</h1>
      <nav aria-label="Contact and profile links">
        <a href="#work-title">Work</a><span aria-hidden="true">·</span>
        <a href="#open-source-title">Open source</a><span aria-hidden="true">·</span>
        <a href="mailto:warresnaet@icloud.com">Email</a><span aria-hidden="true">·</span>
        <a href="https://github.com/SnaetWarre">GitHub</a><span aria-hidden="true">·</span>
        <a href="https://www.linkedin.com/in/warre-snaet-272354370/">LinkedIn</a><span aria-hidden="true">·</span>
        <a href={`${base}cv.html`}>CV</a>
      </nav>
    </header>

    <section aria-labelledby="about-title">
      <h2 class="visually-hidden" id="about-title">About</h2>
      <p>I’m a backend and applied AI engineer from Belgium. I graduated <em>with distinction</em> in AI Engineering at Howest.</p>
      <p>My strongest work is in Python: APIs, data pipelines, computer vision, OCR, applied machine learning, Reinforcement Learning, Generative AI, and the software required to make those systems dependable. During my international internship at 2Ai IPCA, I built a medical-imaging pipeline that turns measurements embedded in echocardiograms into structured research data.</p>
      <p>I’m open to junior backend, software, data, and applied AI engineering roles, with a particular interest in agent infrastructure and MLOps. I also work with C# and TypeScript when a project calls for them, and explore Rust and edge AI on the side.</p>
    </section>

    <section aria-labelledby="experience-title">
      <h2 id="experience-title">Experience</h2>
      <ProjectList projects={experience} />
    </section>

    <section aria-labelledby="work-title">
      <h2 id="work-title">Selected work</h2>
      <ProjectList projects={selectedWork} />
    </section>

    <section aria-labelledby="open-source-title">
      <h2 id="open-source-title">Open source</h2>
      <ProjectList projects={openSource} />
    </section>

    <section aria-labelledby="writing-title">
      <h2 id="writing-title">Writing</h2>
      <ul><li><a href={`${base}blog/blog.html`}>How I built a 26 MB offline AI with Rust and Burn</a></li></ul>
    </section>

    <footer>
      <p>Open to junior backend, software, data, and applied AI engineering roles. The easiest way to reach me is through <a href="https://www.linkedin.com/in/warre-snaet-272354370/">LinkedIn</a> or <a href="mailto:warresnaet@icloud.com">email</a>.</p>
      <p>Warre Snaet, {year}</p>
    </footer>
  </main>
</BaseLayout>
